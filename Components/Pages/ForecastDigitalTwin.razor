@page "/forecast-digital-twin"
@layout MainLayout
@using ApexCharts
@using MudBlazor
@inject IForecastService ForecastService

<MudText Typo="Typo.h3">Forecast & Digital Twin</MudText>

<MudPaper Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-3">Forecast Parameters</MudText>
    <MudSelect T="int"
               Label="Time Frame (Months)"
               @bind-Value="selectedMonths"
               @bind-Value:after="LoadForecastData"
               Dense="true"
               Class="mb-3">
        <MudSelectItem T="int" Value="1">1 Month</MudSelectItem>
        <MudSelectItem T="int" Value="3">3 Months</MudSelectItem>
        <MudSelectItem T="int" Value="6">6 Months</MudSelectItem>
        <MudSelectItem T="int" Value="12">12 Months</MudSelectItem>
    </MudSelect>

    <MudGrid Class="mt-3">
        <MudItem xs="12" md="6">
            <MudTextField @bind-Value="selectedPartNumber"
                          @bind-Value:after="LoadForecastData"
                          Label="Part Number"
                          Variant="Variant.Outlined"
                          Clearable="true" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudTextField @bind-Value="selectedMfgCode"
                          @bind-Value:after="LoadForecastData"
                          Label="MFG Code"
                          Variant="Variant.Outlined"
                          Clearable="true" />
        </MudItem>
    </MudGrid>

    <MudText Typo="Typo.h6" Class="mb-3 mt-4">Digital Twin Scenario Parameters</MudText>
    <MudGrid>
        <MudItem xs="12" md="6">
            <MudNumericField @bind-Value="demandMultiplier"
                             @bind-Value:after="LoadForecastData"
                             Label="Demand Multiplier"
                             Min="0.1"
                             Max="5.0"
                             Step="0.1"
                             Format="N1" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudNumericField @bind-Value="leadTimeShiftDays"
                             @bind-Value:after="LoadForecastData"
                             Label="Lead Time Shift (Days)"
                             Min="-30"
                             Max="30"
                             Step="1" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudNumericField @bind-Value="ssOverrideParts"
                             @bind-Value:after="LoadForecastData"
                             Label="Safety Stock Override (Parts)"
                             Min="0"
                             Step="1"
                             Clearable="true" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudNumericField @bind-Value="ssOverrideLeadTime"
                             @bind-Value:after="LoadForecastData"
                             Label="Safety Stock Lead Time Override (Days)"
                             Min="0"
                             Step="1"
                             Clearable="true" />
        </MudItem>
    </MudGrid>

    <MudGrid Class="mt-3">
        <MudItem xs="12" md="6">
            <MudSwitch T="bool" @bind-Checked="showSafetyStockPartsChart" Label="Show Safety Stock Parts Chart" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudSwitch T="bool" @bind-Checked="showSafetyStockLeadTimeChart" Label="Show Safety Stock Lead Time Chart" />
        </MudItem>
    </MudGrid>
</MudPaper>

@if (isLoading)
{
    <MudProgressCircular Color="MudBlazor.Color.Primary" Indeterminate="true" />
    <MudText>Loading forecast data...</MudText>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <MudAlert Severity="Severity.Error">@errorMessage</MudAlert>
}
else
{
    <MudPaper Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" Class="mb-3">GIT and WIP Over Time</MudText>

        @if (_chartReady && gitWipChartData.Any())
        {
            <ApexChart TItem="ForecastChartPoint"
                       Height="400"
                       Options="gitWipOptions"
                       @key="_gitWipChartKey">

                <ApexPointSeries TItem="ForecastChartPoint"
                                 Items="gitWipChartData"
                                 Name="GIT Balance"
                                 SeriesType="SeriesType.Line"
                                 XValue="p => p.Date"
                                 YValue="p => (decimal)p.GitBalance" />

                <ApexPointSeries TItem="ForecastChartPoint"
                                 Items="gitWipChartData"
                                 Name="WIP Balance"
                                 SeriesType="SeriesType.Line"
                                 XValue="p => p.Date"
                                 YValue="p => (decimal)p.WipBalance" />
            </ApexChart>
        }
        else
        {
            <MudText>No chart data available.</MudText>
        }
    </MudPaper>

    @if (showSafetyStockPartsChart && !string.IsNullOrEmpty(selectedPartNumber))
    {
        <MudPaper Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">Safety Stock (Parts) Over Time</MudText>

            @if (_chartReady && safetyStockPartsData.Any())
            {
                <ApexChart TItem="SafetyStockPartsPoint"
                           Height="400"
                           Options="safetyStockPartsOptions"
                           @key="_safetyStockPartsChartKey">
                    <ApexPointSeries TItem="SafetyStockPartsPoint"
                                     Items="safetyStockPartsData"
                                     Name="Safety Stock Parts"
                                     SeriesType="SeriesType.Line"
                                     XValue="p => p.Date"
                                     YValue="p => (decimal)p.Value" />
                </ApexChart>
            }
            else
            {
                <MudText>No safety stock parts data available.</MudText>
            }
        </MudPaper>
    }

    @if (showSafetyStockLeadTimeChart && !string.IsNullOrEmpty(selectedPartNumber))
    {
        <MudPaper Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">Safety Stock Lead Time Over Time</MudText>

            @if (_chartReady && safetyStockLeadTimeData.Any())
            {
                <ApexChart TItem="SafetyStockLeadTimePoint"
                           Height="400"
                           Options="safetyStockLeadTimeOptions"
                           @key="_safetyStockLeadTimeChartKey">
                    <ApexPointSeries TItem="SafetyStockLeadTimePoint"
                                     Items="safetyStockLeadTimeData"
                                     Name="Safety Stock Lead Time"
                                     SeriesType="SeriesType.Line"
                                     XValue="p => p.Date"
                                     YValue="p => (decimal)p.Value" />
                </ApexChart>
            }
            else
            {
                <MudText>No safety stock lead time data available.</MudText>
            }
        </MudPaper>
    }

    <MudTable Items="@forecastItems" Hover="true" Striped="true">
        <HeaderContent>
            <MudTh>Site</MudTh>
            <MudTh>Part Number</MudTh>
            <MudTh>Date</MudTh>
            <MudTh>WIP Balance</MudTh>
            <MudTh>GIT Balance</MudTh>
            <MudTh>Total Capital (M SEK)</MudTh>
            <MudTh>Safety Stock</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Site</MudTd>
            <MudTd>@context.Part_Number</MudTd>
            <MudTd>@context.Date.ToShortDateString()</MudTd>
            <MudTd>@context.Wip_Balance.ToString("N0")</MudTd>
            <MudTd>@context.Git_Balance.ToString("N0")</MudTd>
            <MudTd>@context.Total_Capital_M_Sek.ToString("N2")</MudTd>
            <MudTd>@context.Safety_Stock_Nr_Of_Parts?.ToString("N0")</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<ForecastItem> forecastItems = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private int selectedMonths = 3;
    private string? selectedPartNumber;
    private string? selectedMfgCode;
    private bool showSafetyStockPartsChart = false;
    private bool showSafetyStockLeadTimeChart = false;

    // Digital Twin Parameters
    private double demandMultiplier = 1.0;
    private int leadTimeShiftDays = 0;
    private double? ssOverrideParts = null;
    private double? ssOverrideLeadTime = null;

    // Apex chart state
    private bool _chartReady;
    private Guid _gitWipChartKey = Guid.NewGuid();
    private Guid _safetyStockPartsChartKey = Guid.NewGuid();
    private Guid _safetyStockLeadTimeChartKey = Guid.NewGuid();

    // Chart data
    private List<ForecastChartPoint> gitWipChartData = new();
    private List<SafetyStockPartsPoint> safetyStockPartsData = new();
    private List<SafetyStockLeadTimePoint> safetyStockLeadTimeData = new();

    // Chart options
    private ApexChartOptions<ForecastChartPoint> gitWipOptions = CreateLineOptions<ForecastChartPoint>("Date", "Balance");
    private ApexChartOptions<SafetyStockPartsPoint> safetyStockPartsOptions = CreateLineOptions<SafetyStockPartsPoint>("Date", "Parts");
    private ApexChartOptions<SafetyStockLeadTimePoint> safetyStockLeadTimeOptions = CreateLineOptions<SafetyStockLeadTimePoint>("Date", "Days");

    protected override async Task OnInitializedAsync()
    {
        await LoadForecastData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _chartReady = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static ApexChartOptions<T> CreateLineOptions<T>(string xTitle, string yTitle) where T : class
    {
        return new ApexChartOptions<T>
        {
            Chart = new Chart
            {
                Toolbar = new Toolbar { Show = true },
                Zoom = new Zoom { Enabled = true }
            },
            Xaxis = new XAxis
            {
                Type = XAxisType.Datetime,
                Title = new AxisTitle { Text = xTitle },
                Labels = new XAxisLabels
                {
                    DatetimeFormatter = new DatetimeFormatter
                    {
                        Day = "dd MMM",
                        Month = "MMM yyyy"
                    }
                }
            },
            Yaxis = new List<YAxis>
            {
                new YAxis
                {
                    Title = new AxisTitle { Text = yTitle }
                }
            },
            Stroke = new Stroke
            {
                Curve = Curve.Smooth,
                Width = 2
            },
            Tooltip = new Tooltip
            {
                X = new TooltipX { Format = "dd MMM yyyy" }
            },
            Colors = new List<string>
            {
                "#5E81AC", "#BF616A", "#A3BE8C", "#EBCB8B", "#B48EAD", "#88C0D0", "#D08770"
            }
        };
    }

    private void RegenerateChartKeys()
    {
        _gitWipChartKey = Guid.NewGuid();
        _safetyStockPartsChartKey = Guid.NewGuid();
        _safetyStockLeadTimeChartKey = Guid.NewGuid();
    }

    private async Task LoadForecastData()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            forecastItems = await ForecastService.GetForecastDataAsync(
                siteFilter: null,
                partNumberFilter: selectedPartNumber,
                mfgCodeFilter: selectedMfgCode,
                months: selectedMonths,
                demandMultiplier: demandMultiplier,
                leadTimeShiftDays: leadTimeShiftDays,
                ssOverrideParts: ssOverrideParts,
                ssOverrideLeadTime: ssOverrideLeadTime
            );

            // GIT + WIP chart
            gitWipChartData = forecastItems
                .GroupBy(x => x.Date)
                .Select(g => new ForecastChartPoint
                {
                    Date = g.Key,
                    GitBalance = (double)g.Sum(x => x.Git_Balance),
                    WipBalance = (double)g.Sum(x => x.Wip_Balance)
                })
                .OrderBy(x => x.Date)
                .ToList();

            // Safety stock charts if part number selected
            if (!string.IsNullOrEmpty(selectedPartNumber))
            {
                var ssData = forecastItems.OrderBy(x => x.Date).ToList();

                var lastPartsValue =
                    ssData.LastOrDefault(x => x.Safety_Stock_Nr_Of_Parts.HasValue)?.Safety_Stock_Nr_Of_Parts ?? 0;

                safetyStockPartsData = ssData
                    .Select(x => new SafetyStockPartsPoint
                    {
                        Date = x.Date,
                        Value = (double)(x.Safety_Stock_Nr_Of_Parts ?? lastPartsValue)
                    })
                    .ToList();

                var lastLeadTimeValue =
                    ssData.LastOrDefault(x => x.Safety_Stock_Lead_Time.HasValue)?.Safety_Stock_Lead_Time ?? 0;

                safetyStockLeadTimeData = ssData
                    .Select(x => new SafetyStockLeadTimePoint
                    {
                        Date = x.Date,
                        Value = (double)(x.Safety_Stock_Lead_Time ?? lastLeadTimeValue)
                    })
                    .ToList();
            }
            else
            {
                safetyStockPartsData.Clear();
                safetyStockLeadTimeData.Clear();
            }

            RegenerateChartKeys();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading forecast data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    public class ForecastChartPoint
    {
        public DateTime Date { get; set; }
        public double GitBalance { get; set; }
        public double WipBalance { get; set; }
    }

    public class SafetyStockPartsPoint
    {
        public DateTime Date { get; set; }
        public double Value { get; set; }
    }

    public class SafetyStockLeadTimePoint
    {
        public DateTime Date { get; set; }
        public double Value { get; set; }
    }
}