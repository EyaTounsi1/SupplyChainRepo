@page "/forecast-digital-twin"
@layout MainLayout
@inject IForecastService ForecastService

<MudText Typo="Typo.h3">Forecast & Digital Twin</MudText>

<MudPaper Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-3">Forecast Parameters</MudText>
    <MudSelect T="int"
               Label="Time Frame (Months)"
               @bind-Value="selectedMonths"
               @bind-Value:after="LoadForecastData"
               Dense="true"
               Class="mb-3">
        <MudSelectItem T="int" Value="1">1 Month</MudSelectItem>
        <MudSelectItem T="int" Value="3">3 Months</MudSelectItem>
        <MudSelectItem T="int" Value="6">6 Months</MudSelectItem>
        <MudSelectItem T="int" Value="12">12 Months</MudSelectItem>
    </MudSelect>

    <MudGrid Class="mt-3">
        <MudItem xs="12" md="6">
            <MudTextField @bind-Value="selectedPartNumber" 
                          @bind-Value:after="LoadForecastData"
                          Label="Part Number" 
                          Variant="Variant.Outlined" 
                          Clearable="true" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudTextField @bind-Value="selectedMfgCode" 
                          @bind-Value:after="LoadForecastData"
                          Label="MFG Code" 
                          Variant="Variant.Outlined" 
                          Clearable="true" />
        </MudItem>
    </MudGrid>

    <MudText Typo="Typo.h6" Class="mb-3 mt-4">Digital Twin Scenario Parameters</MudText>
    <MudGrid>
        <MudItem xs="12" md="6">
            <MudNumericField @bind-Value="demandMultiplier" 
                             @bind-Value:after="LoadForecastData"
                             Label="Demand Multiplier" 
                             Min="0.1" 
                             Max="5.0" 
                             Step="0.1" 
                             Format="N1" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudNumericField @bind-Value="leadTimeShiftDays" 
                             @bind-Value:after="LoadForecastData"
                             Label="Lead Time Shift (Days)" 
                             Min="-30" 
                             Max="30" 
                             Step="1" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudNumericField @bind-Value="ssOverrideParts" 
                             @bind-Value:after="LoadForecastData"
                             Label="Safety Stock Override (Parts)" 
                             Min="0" 
                             Step="1" 
                             Clearable="true" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudNumericField @bind-Value="ssOverrideLeadTime" 
                             @bind-Value:after="LoadForecastData"
                             Label="Safety Stock Lead Time Override (Days)" 
                             Min="0" 
                             Step="1" 
                             Clearable="true" />
        </MudItem>
    </MudGrid>

    <MudGrid Class="mt-3">
        <MudItem xs="12" md="6">
            <MudSwitch T="bool" @bind-Checked="showSafetyStockPartsChart" Label="Show Safety Stock Parts Chart" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudSwitch T="bool" @bind-Checked="showSafetyStockLeadTimeChart" Label="Show Safety Stock Lead Time Chart" />
        </MudItem>
    </MudGrid>
</MudPaper>

@if (isLoading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    <MudText>Loading forecast data...</MudText>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <MudAlert Severity="Severity.Error">@errorMessage</MudAlert>
}
else
{
    <MudPaper Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" Class="mb-3">GIT and WIP Over Time</MudText>
        <MudChart ChartType="ChartType.Line" 
                  ChartSeries="chartSeries" 
                  XAxisLabels="chartLabels" 
                  Width="100%" 
                  Height="400px" />
    </MudPaper>

    @if (showSafetyStockPartsChart && !string.IsNullOrEmpty(selectedPartNumber))
    {
        <MudPaper Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">Safety Stock (Parts) Over Time</MudText>
            <MudChart ChartType="ChartType.Line" 
                      ChartSeries="safetyStockPartsSeries" 
                      XAxisLabels="chartLabels" 
                      Width="100%" 
                      Height="400px" />
        </MudPaper>
    }

    @if (showSafetyStockLeadTimeChart && !string.IsNullOrEmpty(selectedPartNumber))
    {
        <MudPaper Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">Safety Stock Lead Time Over Time</MudText>
            <MudChart ChartType="ChartType.Line" 
                      ChartSeries="safetyStockLeadTimeSeries" 
                      XAxisLabels="chartLabels" 
                      Width="100%" 
                      Height="400px" />
        </MudPaper>
    }

    <MudTable Items="@forecastItems" Hover="true" Striped="true">
        <HeaderContent>
            <MudTh>Site</MudTh>
            <MudTh>Part Number</MudTh>
            <MudTh>Date</MudTh>
            <MudTh>WIP Balance</MudTh>
            <MudTh>GIT Balance</MudTh>
            <MudTh>Total Capital (M SEK)</MudTh>
            <MudTh>Safety Stock</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Site</MudTd>
            <MudTd>@context.Part_Number</MudTd>
            <MudTd>@context.Date.ToShortDateString()</MudTd>
            <MudTd>@context.Wip_Balance.ToString("N0")</MudTd>
            <MudTd>@context.Git_Balance.ToString("N0")</MudTd>
            <MudTd>@context.Total_Capital_M_Sek.ToString("N2")</MudTd>
            <MudTd>@context.Safety_Stock_Nr_Of_Parts?.ToString("N0")</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<ForecastItem> forecastItems = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private int selectedMonths = 3;
    private string? selectedPartNumber;
    private string? selectedMfgCode;
    private List<ChartSeries> chartSeries = new();
    private string[] chartLabels = Array.Empty<string>();
    private bool showSafetyStockPartsChart = false;
    private bool showSafetyStockLeadTimeChart = false;
    private List<ChartSeries> safetyStockPartsSeries = new();
    private List<ChartSeries> safetyStockLeadTimeSeries = new();

    // Digital Twin Parameters
    private double demandMultiplier = 1.0;
    private int leadTimeShiftDays = 0;
    private double? ssOverrideParts = null;
    private double? ssOverrideLeadTime = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadForecastData();
    }

    private async Task LoadForecastData()
    {
        isLoading = true;
        errorMessage = string.Empty;
        try
        {
            forecastItems = await ForecastService.GetForecastDataAsync(siteFilter: null, partNumberFilter: selectedPartNumber, mfgCodeFilter: selectedMfgCode, months: selectedMonths, demandMultiplier: demandMultiplier, leadTimeShiftDays: leadTimeShiftDays, ssOverrideParts: ssOverrideParts, ssOverrideLeadTime: ssOverrideLeadTime);

            // Prepare chart data
            var aggregatedData = forecastItems
                .GroupBy(x => x.Date)
                .Select(g => new
                {
                    Date = g.Key,
                    GitTotal = g.Sum(x => x.Git_Balance),
                    WipTotal = g.Sum(x => x.Wip_Balance)
                })
                .OrderBy(x => x.Date)
                .ToList();

            chartLabels = aggregatedData.Select(x => x.Date.ToShortDateString()).ToArray();
            chartSeries = new List<ChartSeries>
            {
                new ChartSeries { Name = "GIT Balance", Data = aggregatedData.Select(x => (double)x.GitTotal).ToArray() },
                new ChartSeries { Name = "WIP Balance", Data = aggregatedData.Select(x => (double)x.WipTotal).ToArray() }
            };

            // Prepare safety stock charts if part number is selected
            if (!string.IsNullOrEmpty(selectedPartNumber))
            {
                var ssData = forecastItems.OrderBy(x => x.Date).ToList();
                
                // Find the last known safety stock parts value to extend into the future
                var lastPartsValue = ssData.LastOrDefault(x => x.Safety_Stock_Nr_Of_Parts.HasValue)?.Safety_Stock_Nr_Of_Parts ?? 0;
                safetyStockPartsSeries = new List<ChartSeries>
                {
                    new ChartSeries { Name = "Safety Stock Parts", Data = ssData.Select(x => (double)(x.Safety_Stock_Nr_Of_Parts ?? lastPartsValue)).ToArray() }
                };
                
                // Find the last known safety stock lead time value to extend into the future
                var lastLeadTimeValue = ssData.LastOrDefault(x => x.Safety_Stock_Lead_Time.HasValue)?.Safety_Stock_Lead_Time ?? 0;
                safetyStockLeadTimeSeries = new List<ChartSeries>
                {
                    new ChartSeries { Name = "Safety Stock Lead Time", Data = ssData.Select(x => (double)(x.Safety_Stock_Lead_Time ?? lastLeadTimeValue)).ToArray() }
                };
            }
            else
            {
                safetyStockPartsSeries.Clear();
                safetyStockLeadTimeSeries.Clear();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading forecast data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}