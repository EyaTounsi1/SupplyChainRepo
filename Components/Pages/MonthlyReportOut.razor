
@page "/ad-hoc/monthly-report-out"

@using System
@using Microsoft.AspNetCore.Components.Forms
@using PartTracker.Models
@inject IServiceProvider ServiceProvider

<h3>Monthly Report Out</h3>

<EditForm Model="@reportOut" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <div class="mb-3">
        <label>Forecast this month (shifts):</label>
        <InputNumber @bind-Value="reportOut.ForecastThisMonth" class="form-control" />
    </div>
    <div class="mb-3">
        <label>New Anticipation stock in shifts:</label>
        <InputNumber @bind-Value="reportOut.NewAnticipationStockInShifts" class="form-control" />
    </div>
    <div class="mb-3">
        <label>New Lead time (days):</label>
        <InputNumber @bind-Value="reportOut.NewLeadTime" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Part number:</label>
        <InputText @bind-Value="reportOut.PartNumber" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Submit</button>
</EditForm>

<hr />

@if (showResults)
{
    <div class="alert alert-info">
        <b>Forecasted:</b> @forecastedMSEK.ToString("F2") MSEK<br />
        <b>Actuals:</b> @actualsMSEK.ToString("F2") MSEK<br />
        <b>Deviation:</b> @(deviationMSEK.ToString("F2")) MSEK
    </div>
}

@code {
    private ReportOutModel reportOut = new();
    private bool showResults = false;
    private double forecastedMSEK;
    private double actualsMSEK;
    private double deviationMSEK;

    private async void HandleValidSubmit()
    {
        // Log timestamp automatically
        reportOut.Timestamp = DateTime.Now;

        // Save to AutomationDb.ReportOut
        using (var scope = ServiceProvider.CreateScope())
        {
            var db = (AutomationDbContext)scope.ServiceProvider.GetService(typeof(AutomationDbContext));
            if (db != null)
            {
                var entity = new ReportOut
                {
                    ForecastThisMonth = reportOut.ForecastThisMonth,
                    NewAnticipationStockInShifts = reportOut.NewAnticipationStockInShifts,
                    NewLeadTime = reportOut.NewLeadTime,
                    PartNumber = reportOut.PartNumber,
                    Timestamp = reportOut.Timestamp
                };
                db.ReportOuts.Add(entity);
                await db.SaveChangesAsync();
            }
        }

        // Generate random normal values for forecasted and actuals (mean=100, stddev=10)
        var rand = new Random();
        double NextNormal(double mean, double stddev)
        {
            // Box-Muller transform
            var u1 = 1.0 - rand.NextDouble();
            var u2 = 1.0 - rand.NextDouble();
            var randStdNormal = Math.Sqrt(-2.0 * Math.Log(u1)) * Math.Sin(2.0 * Math.PI * u2);
            return mean + stddev * randStdNormal;
        }
        forecastedMSEK = NextNormal(100, 10);
        actualsMSEK = NextNormal(100, 10);
        deviationMSEK = forecastedMSEK - actualsMSEK;
        showResults = true;
    }

    public class ReportOutModel
    {
        public double ForecastThisMonth { get; set; }
        public double NewAnticipationStockInShifts { get; set; }
        public double NewLeadTime { get; set; }
        public string PartNumber { get; set; } = string.Empty;
        public DateTime Timestamp { get; set; }
    }
}
