@page "/inventory-alerts/piwds"

@using PartTracker.Shared.Services
@using Microsoft.JSInterop
@using System.Data
@using ApexCharts
@inject SnowflakeService SnowflakeService
@inject IJSRuntime JSRuntime
@using MudBlazor

<h3>PIWDs</h3>

<MudPaper Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-3">Date Range Filter</MudText>
    <MudGrid>
        <MudItem xs="12" md="3">
            <MudTextField @bind-Value="_rangeStartDate"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Label="From Date" InputType="InputType.Date" Format="yyyy-MM-dd" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudTextField @bind-Value="_rangeEndDate"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Label="To Date" InputType="InputType.Date" Format="yyyy-MM-dd" />
        </MudItem>
        <MudItem xs="12" md="2">
            <MudTextField @bind-Value="_rangeStartTime"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Label="From Time" InputType="InputType.Time" />
        </MudItem>
        <MudItem xs="12" md="2">
            <MudTextField @bind-Value="_rangeEndTime"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Label="To Time" InputType="InputType.Time" />
        </MudItem>
        <MudItem xs="12" md="1">
            <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary"
                       Size="MudBlazor.Size.Large" OnClick="ApplyFilterAsync"
                       FullWidth="true" Style="height:56px;">
                <MudIcon Icon="@Icons.Material.Filled.FilterAlt" />
            </MudButton>
        </MudItem>
        <MudItem xs="12" md="1">
            <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Surface"
                       Size="MudBlazor.Size.Large" OnClick="ResetFilterAsync"
                       FullWidth="true" Style="height:56px;">
                <MudIcon Icon="@Icons.Material.Filled.Refresh" />
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-3">Parts Running Out Over Next 90 Days</MudText>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudSwitch @bind-Value="chinaOnly" @bind-Value:after="OnFilterChanged" Label="Only China parts" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudSwitch @bind-Value="excludeSweden" @bind-Value:after="OnFilterChanged" Label="Exclude Sweden parts" />
        </MudItem>
    </MudGrid>

    @if (isLoading)
    {
        <MudProgressCircular Color="MudBlazor.Color.Primary" Indeterminate="true" />
    }
    else if (_chartReady && runOutData.Any())
    {
        <ApexChart TItem="PartsRunOutItem"
                   Height="400"
                   Options="runOutOptions"
                   @key="_runOutChartKey">
            <ApexPointSeries TItem="PartsRunOutItem"
                             Items="runOutData"
                             Name="Parts Running Out"
                             SeriesType="SeriesType.Line"
                             XValue="p => p.RunOutDay"
                             YValue="p => (decimal)p.PartsRunningOut" />
        </ApexChart>
    }
    else
    {
        <MudText>No data available.</MudText>
    }
</MudPaper>

<MudPaper Class="pa-4 mb-4 mt-4">
    <MudText Typo="Typo.h6" Class="mb-3">Demand Changes Over Planning Time</MudText>
    <MudText>This shows whether the planned amount for a given day was changed as planning evolved.</MudText>

    @if (isLoadingDemand)
    {
        <MudProgressCircular Color="MudBlazor.Color.Primary" Indeterminate="true" />
    }
    else if (_chartReady && demandData.Any())
    {
        <ApexChart TItem="DemandItem"
                   Height="400"
                   Options="demandOptions"
                   @key="_demandChartKey">
            <ApexPointSeries TItem="DemandItem"
                             Items="demandData"
                             Name="Planned Amount"
                             SeriesType="SeriesType.Line"
                             XValue="p => p.PlanningTime"
                             YValue="p => (decimal)p.PlannedAmount" />
        </ApexChart>
    }
    else
    {
        <MudText>No demand data available.</MudText>
    }
</MudPaper>

<MudPaper Class="pa-4 mb-4 mt-4">
    <MudText Typo="Typo.h6" Class="mb-3">Earliest vs Latest Plan Comparison</MudText>
    <MudText>This compares the earliest plan vs latest plan for each production day to see if demand increased or decreased. Delta > 0 means later plans increased demand.</MudText>

    @if (isLoadingComparison)
    {
        <MudProgressCircular Color="MudBlazor.Color.Primary" Indeterminate="true" />
    }
    else if (_chartReady && comparisonData.Any())
    {
        <ApexChart TItem="ComparisonItem"
                   Height="400"
                   Options="comparisonOptions"
                   @key="_comparisonChartKey">
            <ApexPointSeries TItem="ComparisonItem"
                             Items="comparisonData"
                             Name="Delta Amount"
                             SeriesType="SeriesType.Bar"
                             XValue="p => p.ProductionDay"
                             YValue="p => (decimal)p.TotalDelta" />
        </ApexChart>
    }
    else
    {
        <MudText>No comparison data available.</MudText>
    }
</MudPaper>

<MudPaper Class="pa-4 mb-4 mt-4">
    <MudText Typo="Typo.h6" Class="mb-3">Daily View of Plan Changes</MudText>
    <MudText>This shows how planned amounts change across production days for different planning times. If earlier days gain volume and later days lose, the plan was pulled ahead.</MudText>

    @if (isLoadingDaily)
    {
        <MudProgressCircular Color="MudBlazor.Color.Primary" Indeterminate="true" />
    }
    else if (_chartReady && dailyData.Any())
    {
        <ApexChart TItem="DailyItem"
                   Height="400"
                   Options="dailyOptions"
                   @key="_dailyChartKey">
            @foreach (var pt in dailyData.Select(d => d.PlanningTime).Distinct().OrderBy(t => t))
            {
                <ApexPointSeries TItem="DailyItem"
                                 Items="dailyData.Where(d => d.PlanningTime == pt).ToList()"
                                 Name="@pt.ToString("yyyy-MM-dd HH:mm")"
                                 SeriesType="SeriesType.Line"
                                 XValue="p => p.ProductionDay"
                                 YValue="p => (decimal)p.PlannedAmount" />
            }
        </ApexChart>
    }
    else
    {
        <MudText>No daily data available.</MudText>
    }
</MudPaper>

<MudPaper Class="pa-4 mb-4 mt-4">
    <MudText Typo="Typo.h6" Class="mb-3">Planning Lead Time Comparison</MudText>
    <MudText>This shows the average planning lead days for production days. Higher values mean planned well in advance.</MudText>

    @if (isLoadingLead)
    {
        <MudProgressCircular Color="MudBlazor.Color.Primary" Indeterminate="true" />
    }
    else if (_chartReady && leadData.Any())
    {
        <ApexChart TItem="LeadItem"
                   Height="400"
                   Options="leadOptions"
                   @key="_leadChartKey">
            <ApexPointSeries TItem="LeadItem"
                             Items="leadData"
                             Name="Avg Planning Lead Days"
                             SeriesType="SeriesType.Line"
                             XValue="p => p.ProductionDay"
                             YValue="p => (decimal)p.AvgPlanningLeadDays" />
        </ApexChart>
    }
    else
    {
        <MudText>No lead time data available.</MudText>
    }
</MudPaper>

@code {
    private bool isLoading = true;
    private bool chinaOnly = false;
    private bool excludeSweden = false;
    private bool isLoadingDemand = true;
    private bool isLoadingComparison = true;
    private bool isLoadingDaily = true;
    private bool isLoadingLead = true;
    private bool _chartReady;

    // --- Period / Time filter (same pattern as FleetManagement) ---
    private DateTime? _rangeStartDate;
    private DateTime? _rangeEndDate;
    private TimeSpan? _rangeStartTime;
    private TimeSpan? _rangeEndTime;

    // Data lists
    private List<PartsRunOutItem> runOutData = new();
    private List<DemandItem> demandData = new();
    private List<ComparisonItem> comparisonData = new();
    private List<DailyItem> dailyData = new();
    private List<LeadItem> leadData = new();

    // Chart keys for re-render
    private Guid _runOutChartKey = Guid.NewGuid();
    private Guid _demandChartKey = Guid.NewGuid();
    private Guid _comparisonChartKey = Guid.NewGuid();
    private Guid _dailyChartKey = Guid.NewGuid();
    private Guid _leadChartKey = Guid.NewGuid();

    // ApexChart options
    private ApexChartOptions<PartsRunOutItem> runOutOptions = CreateLineOptions<PartsRunOutItem>("Date", "Parts Running Out");
    private ApexChartOptions<DemandItem> demandOptions = CreateLineOptions<DemandItem>("Planning Time", "Planned Amount");
    private ApexChartOptions<ComparisonItem> comparisonOptions = CreateBarOptions<ComparisonItem>("Production Day", "Delta Amount");
    private ApexChartOptions<DailyItem> dailyOptions = CreateLineOptions<DailyItem>("Production Day", "Planned Amount");
    private ApexChartOptions<LeadItem> leadOptions = CreateLineOptions<LeadItem>("Production Day", "Avg Planning Lead Days");

    private static ApexChartOptions<T> CreateLineOptions<T>(string xTitle, string yTitle) where T : class
    {
        return new ApexChartOptions<T>
        {
            Chart = new Chart
            {
                Toolbar = new Toolbar { Show = true },
                Zoom = new Zoom { Enabled = true }
            },
            Xaxis = new XAxis
            {
                Type = XAxisType.Datetime,
                Title = new AxisTitle { Text = xTitle },
                Labels = new XAxisLabels
                {
                    DatetimeFormatter = new DatetimeFormatter
                    {
                        Day = "dd MMM",
                        Month = "MMM yyyy"
                    }
                }
            },
            Yaxis = new List<YAxis>
            {
                new YAxis
                {
                    Title = new AxisTitle { Text = yTitle }
                }
            },
            Stroke = new Stroke
            {
                Curve = Curve.Smooth,
                Width = 2
            },
            Tooltip = new Tooltip
            {
                X = new TooltipX { Format = "dd MMM yyyy" }
            },
            Colors = new List<string> { "#5E81AC", "#BF616A", "#A3BE8C", "#EBCB8B", "#B48EAD", "#88C0D0", "#D08770" }
        };
    }

    private static ApexChartOptions<T> CreateBarOptions<T>(string xTitle, string yTitle) where T : class
    {
        return new ApexChartOptions<T>
        {
            Chart = new Chart
            {
                Toolbar = new Toolbar { Show = true },
                Zoom = new Zoom { Enabled = true }
            },
            Xaxis = new XAxis
            {
                Type = XAxisType.Datetime,
                Title = new AxisTitle { Text = xTitle },
                Labels = new XAxisLabels
                {
                    DatetimeFormatter = new DatetimeFormatter
                    {
                        Day = "dd MMM",
                        Month = "MMM yyyy"
                    }
                }
            },
            Yaxis = new List<YAxis>
            {
                new YAxis
                {
                    Title = new AxisTitle { Text = yTitle }
                }
            },
            PlotOptions = new PlotOptions
            {
                Bar = new PlotOptionsBar
                {
                    ColumnWidth = "60%"
                }
            },
            Tooltip = new Tooltip
            {
                X = new TooltipX { Format = "dd MMM yyyy" }
            },
            Colors = new List<string> { "#5E81AC", "#BF616A", "#A3BE8C", "#EBCB8B", "#B48EAD" }
        };
    }

    private (DateTime From, DateTime To) GetSelectedRange()
    {
        var startDate = _rangeStartDate ?? DateTime.Today.AddDays(-90);
        var endDate = _rangeEndDate ?? DateTime.Today;

        var startTime = _rangeStartTime ?? TimeSpan.Zero;
        var endTime = _rangeEndTime ?? new TimeSpan(23, 59, 59);

        var from = startDate.Date + startTime;
        var to = endDate.Date + endTime;

        if (from > to) (from, to) = (to, from);

        return (from, to);
    }

    private async Task ApplyFilterAsync()
    {
        await LoadAllChartsAsync();
        RegenerateAllChartKeys();
        await InvokeAsync(StateHasChanged);
    }

    private async Task ResetFilterAsync()
    {
        _rangeStartDate = null;
        _rangeEndDate = null;
        _rangeStartTime = null;
        _rangeEndTime = null;
        await LoadAllChartsAsync();
        RegenerateAllChartKeys();
        await InvokeAsync(StateHasChanged);
    }

    private void RegenerateAllChartKeys()
    {
        _runOutChartKey = Guid.NewGuid();
        _demandChartKey = Guid.NewGuid();
        _comparisonChartKey = Guid.NewGuid();
        _dailyChartKey = Guid.NewGuid();
        _leadChartKey = Guid.NewGuid();
    }

    private async Task LoadAllChartsAsync()
    {
        await LoadChartData();
        await LoadDemandChartData();
        await LoadComparisonChartData();
        await LoadDailyChartData();
        await LoadLeadChartData();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAllChartsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _chartReady = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnFilterChanged()
    {
        await LoadChartData();
        _runOutChartKey = Guid.NewGuid();
    }

    private async Task LoadChartData()
    {
        isLoading = true;
        try
        {
            var (from, to) = GetSelectedRange();
            var daysAhead = (int)(to.Date - DateTime.Today).TotalDays;
            if (daysAhead < 1) daysAhead = 90;

            string chinaFilter = chinaOnly ? @" AND PART_NUMBER IN (
                SELECT PART_NUMBER
                FROM MANUFACTURING_ENTERPRISE_DATA_PRODUCTS.PART_INFORMATION_AS_MANUFACTURED.PART_INFORMATION_AS_MANUFACTURED
                WHERE CURRENCY = 'CNY'
                  AND CURRENT_DATE BETWEEN INTRODUCTION_DATE AND OUTGOING_DATE
                  AND SITE = INVENTORY_COVERAGE_AS_MANUFACTURED.SITE
            )" : "";

            string swedenFilter = excludeSweden ? @" AND PART_NUMBER NOT IN (
                SELECT PART_NUMBER
                FROM MANUFACTURING_ENTERPRISE_DATA_PRODUCTS.PART_INFORMATION_AS_MANUFACTURED.PART_INFORMATION_AS_MANUFACTURED
                WHERE CURRENCY = 'SEK'
                  AND SITE = INVENTORY_COVERAGE_AS_MANUFACTURED.SITE
            )" : "";

            string sql = $@"
SELECT
    AVAILABLE_INVENTORY_RUN_OUT_DATE AS run_out_day,
    COUNT(DISTINCT PART_NUMBER) AS parts_running_out
FROM MANUFACTURING_ENTERPRISE_DATA_PRODUCTS.INVENTORY_COVERAGE_AS_MANUFACTURED.INVENTORY_COVERAGE_AS_MANUFACTURED
WHERE AVAILABLE_INVENTORY_RUN_OUT_DATE IS NOT NULL
  AND AVAILABLE_INVENTORY_RUN_OUT_DATE >= '{from:yyyy-MM-dd}'
  AND AVAILABLE_INVENTORY_RUN_OUT_DATE < '{to:yyyy-MM-dd}'
  AND PART_NUMBER NOT IN (
      SELECT DISTINCT PART_NUMBER
      FROM MANUFACTURING_ENTERPRISE_DATA_PRODUCTS.DELIVERY_SCHEDULE_AS_MANUFACTURED.DELIVERY_SCHEDULE_AS_MANUFACTURED
      WHERE TO_DATE(DEPARTURE_TIME_EARLIEST) = TO_DATE(ARRIVAL_TIME_EARLIEST)
        AND SITE = INVENTORY_COVERAGE_AS_MANUFACTURED.SITE
  ){chinaFilter}{swedenFilter}
GROUP BY AVAILABLE_INVENTORY_RUN_OUT_DATE
ORDER BY AVAILABLE_INVENTORY_RUN_OUT_DATE;
";

            var dataTable = await SnowflakeService.QueryAsync(sql, "ManufacturingEnterpriseDataProducts");

            runOutData = new List<PartsRunOutItem>();
            foreach (DataRow row in dataTable.Rows)
            {
                runOutData.Add(new PartsRunOutItem
                {
                    RunOutDay = Convert.ToDateTime(row["run_out_day"]),
                    PartsRunningOut = Convert.ToInt32(row["parts_running_out"])
                });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadDemandChartData()
    {
        isLoadingDemand = true;
        try
        {
            var (from, to) = GetSelectedRange();

            string sql = $@"
SELECT
    SITE,
    PLANNING_POINT,
    PART_NUMBER,
    PRODUCTION_DAY,
    SHIFT,
    PLANNING_TIME,
    SUM(PART_AMOUNT) AS planned_amount
FROM MANUFACTURING_ENTERPRISE_DATA_PRODUCTS.PART_DEMAND_AS_MANUFACTURED.PART_DEMAND_AS_MANUFACTURED_ALL_PLANNING_TIMES
WHERE SITE = 'VCT'
  AND PART_NUMBER = '80041945'
  AND PLANNING_TIME >= '{from:yyyy-MM-dd HH:mm:ss}'
  AND PLANNING_TIME <= '{to:yyyy-MM-dd HH:mm:ss}'
  AND PRODUCTION_DAY = (
      SELECT MAX(PRODUCTION_DAY)
      FROM MANUFACTURING_ENTERPRISE_DATA_PRODUCTS.PART_DEMAND_AS_MANUFACTURED.PART_DEMAND_AS_MANUFACTURED_ALL_PLANNING_TIMES
      WHERE SITE = 'VCT' AND PART_NUMBER = '80041945'
  )
GROUP BY
    SITE,
    PLANNING_POINT,
    PART_NUMBER,
    PRODUCTION_DAY,
    SHIFT,
    PLANNING_TIME
ORDER BY
    PRODUCTION_DAY,
    SHIFT,
    PLANNING_TIME;
";

            var dataTable = await SnowflakeService.QueryAsync(sql, "ManufacturingEnterpriseDataProducts");

            demandData = new List<DemandItem>();
            foreach (DataRow row in dataTable.Rows)
            {
                demandData.Add(new DemandItem
                {
                    PlanningTime = Convert.ToDateTime(row["planning_time"]),
                    PlannedAmount = Convert.ToDouble(row["planned_amount"])
                });
            }

            demandData = demandData.OrderBy(d => d.PlanningTime).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoadingDemand = false;
        }
    }

    private async Task LoadComparisonChartData()
    {
        isLoadingComparison = true;
        try
        {
            var (from, to) = GetSelectedRange();

            string sql = $@"
WITH demand_snapshots AS (
    SELECT
        SITE,
        PLANNING_POINT,
        PART_NUMBER,
        PRODUCTION_DAY,
        SHIFT,
        PLANNING_TIME,
        SUM(PART_AMOUNT) AS planned_amount
    FROM MANUFACTURING_ENTERPRISE_DATA_PRODUCTS.PART_DEMAND_AS_MANUFACTURED.PART_DEMAND_AS_MANUFACTURED_ALL_PLANNING_TIMES
    WHERE SITE = 'VCT'
      AND PRODUCTION_DAY >= '{from:yyyy-MM-dd}'
      AND PRODUCTION_DAY <= '{to:yyyy-MM-dd}'
    GROUP BY
        SITE,
        PLANNING_POINT,
        PART_NUMBER,
        PRODUCTION_DAY,
        SHIFT,
        PLANNING_TIME
),
ranked AS (
    SELECT
        *,
        ROW_NUMBER() OVER (
            PARTITION BY SITE, PLANNING_POINT, PART_NUMBER, PRODUCTION_DAY, SHIFT
            ORDER BY PLANNING_TIME ASC
        ) AS rn_first,
        ROW_NUMBER() OVER (
            PARTITION BY SITE, PLANNING_POINT, PART_NUMBER, PRODUCTION_DAY, SHIFT
            ORDER BY PLANNING_TIME DESC
        ) AS rn_last
    FROM demand_snapshots
),
first_plan AS (
    SELECT
        SITE,
        PLANNING_POINT,
        PART_NUMBER,
        PRODUCTION_DAY,
        SHIFT,
        PLANNING_TIME AS first_planning_time,
        planned_amount AS first_planned_amount
    FROM ranked
    WHERE rn_first = 1
),
last_plan AS (
    SELECT
        SITE,
        PLANNING_POINT,
        PART_NUMBER,
        PRODUCTION_DAY,
        SHIFT,
        PLANNING_TIME AS last_planning_time,
        planned_amount AS last_planned_amount
    FROM ranked
    WHERE rn_last = 1
)
SELECT
    f.PRODUCTION_DAY,
    SUM(l.last_planned_amount - f.first_planned_amount) AS total_delta
FROM first_plan f
JOIN last_plan l
    ON f.SITE = l.SITE
   AND f.PLANNING_POINT = l.PLANNING_POINT
   AND f.PART_NUMBER = l.PART_NUMBER
   AND f.PRODUCTION_DAY = l.PRODUCTION_DAY
   AND f.SHIFT = l.SHIFT
GROUP BY f.PRODUCTION_DAY
ORDER BY f.PRODUCTION_DAY;
";

            var dataTable = await SnowflakeService.QueryAsync(sql, "ManufacturingEnterpriseDataProducts");

            comparisonData = new List<ComparisonItem>();
            foreach (DataRow row in dataTable.Rows)
            {
                comparisonData.Add(new ComparisonItem
                {
                    ProductionDay = Convert.ToDateTime(row["production_day"]),
                    TotalDelta = Convert.ToDouble(row["total_delta"])
                });
            }

            comparisonData = comparisonData.OrderBy(d => d.ProductionDay).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoadingComparison = false;
        }
    }

    private async Task LoadDailyChartData()
    {
        isLoadingDaily = true;
        try
        {
            var (from, to) = GetSelectedRange();

            string sql = $@"
WITH ranked_planning_times AS (
    SELECT
        PLANNING_TIME,
        ROW_NUMBER() OVER (ORDER BY PLANNING_TIME DESC) AS rn
    FROM (
        SELECT DISTINCT PLANNING_TIME
        FROM MANUFACTURING_ENTERPRISE_DATA_PRODUCTS.PART_DEMAND_AS_MANUFACTURED.PART_DEMAND_AS_MANUFACTURED_ALL_PLANNING_TIMES
        WHERE SITE = 'VCT'
          AND PLANNING_TIME >= '{from:yyyy-MM-dd HH:mm:ss}'
          AND PLANNING_TIME <= '{to:yyyy-MM-dd HH:mm:ss}'
    ) pt
)
SELECT
    pt.PLANNING_TIME,
    pd.PRODUCTION_DAY,
    SUM(pd.PART_AMOUNT) AS planned_amount
FROM MANUFACTURING_ENTERPRISE_DATA_PRODUCTS.PART_DEMAND_AS_MANUFACTURED.PART_DEMAND_AS_MANUFACTURED_ALL_PLANNING_TIMES pd
JOIN ranked_planning_times pt ON pd.PLANNING_TIME = pt.PLANNING_TIME
WHERE pd.SITE = 'VCT'
  AND pt.rn <= 5
  AND pd.PRODUCTION_DAY >= '{from:yyyy-MM-dd}'
  AND pd.PRODUCTION_DAY <= '{to:yyyy-MM-dd}'
GROUP BY pt.PLANNING_TIME, pd.PRODUCTION_DAY
ORDER BY pd.PRODUCTION_DAY, pt.PLANNING_TIME;
";

            var dataTable = await SnowflakeService.QueryAsync(sql, "ManufacturingEnterpriseDataProducts");

            dailyData = new List<DailyItem>();
            foreach (DataRow row in dataTable.Rows)
            {
                dailyData.Add(new DailyItem
                {
                    PlanningTime = Convert.ToDateTime(row["planning_time"]),
                    ProductionDay = Convert.ToDateTime(row["production_day"]),
                    PlannedAmount = Convert.ToDouble(row["planned_amount"])
                });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoadingDaily = false;
        }
    }

    private async Task LoadLeadChartData()
    {
        isLoadingLead = true;
        try
        {
            var (from, to) = GetSelectedRange();

            string sql = $@"
SELECT
    PRODUCTION_DAY,
    AVG(DATEDIFF(DAY, PLANNING_TIME, PRODUCTION_DAY)) AS avg_planning_lead_days
FROM MANUFACTURING_ENTERPRISE_DATA_PRODUCTS.PART_DEMAND_AS_MANUFACTURED.PART_DEMAND_AS_MANUFACTURED_ALL_PLANNING_TIMES
WHERE SITE = 'VCT'
  AND PRODUCTION_DAY >= '{from:yyyy-MM-dd}'
  AND PRODUCTION_DAY <= '{to:yyyy-MM-dd}'
GROUP BY PRODUCTION_DAY
ORDER BY PRODUCTION_DAY;
";

            var dataTable = await SnowflakeService.QueryAsync(sql, "ManufacturingEnterpriseDataProducts");

            leadData = new List<LeadItem>();
            foreach (DataRow row in dataTable.Rows)
            {
                leadData.Add(new LeadItem
                {
                    ProductionDay = Convert.ToDateTime(row["production_day"]),
                    AvgPlanningLeadDays = Convert.ToDouble(row["avg_planning_lead_days"])
                });
            }

            leadData = leadData.OrderBy(d => d.ProductionDay).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoadingLead = false;
        }
    }

    public class PartsRunOutItem
    {
        public DateTime RunOutDay { get; set; }
        public int PartsRunningOut { get; set; }
    }

    public class DemandItem
    {
        public DateTime PlanningTime { get; set; }
        public double PlannedAmount { get; set; }
    }

    public class ComparisonItem
    {
        public DateTime ProductionDay { get; set; }
        public double TotalDelta { get; set; }
    }

    public class DailyItem
    {
        public DateTime PlanningTime { get; set; }
        public DateTime ProductionDay { get; set; }
        public double PlannedAmount { get; set; }
    }

    public class LeadItem
    {
        public DateTime ProductionDay { get; set; }
        public double AvgPlanningLeadDays { get; set; }
    }
}